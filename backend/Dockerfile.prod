# Production Dockerfile for FastAPI backend + Celery worker.
#
# Build context is the REPO ROOT (not backend/) so we can also COPY
# .claude/skills/netsuite-*/ into the image — the oracle_skill_seeder reads
# those files at runtime to populate the workspace agent's RAG partitions.
#
# Usage from repo root:
#   docker build -f backend/Dockerfile.prod -t backend .
#   docker run -p 8000:8000 backend

FROM python:3.11-slim AS base

# Prevent Python from writing .pyc files and enable unbuffered output.
# ORACLE_SKILLS_ROOT tells oracle_skill_seeder where to walk for vendored
# Oracle skill content (set to /app, where we COPY them below).
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    ORACLE_SKILLS_ROOT=/app

WORKDIR /app

# Install system dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends gcc libpq-dev && \
    rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY backend/pyproject.toml .
RUN pip install --no-cache-dir . && \
    apt-get purge -y --auto-remove gcc

# Install Node.js 20 + Java (JRE) + suitecloud CLI for workspace validate/deploy.
# Pinned to major v3 of the CLI (plan's ^2 was unreachable — Oracle removed the
# 2024.2.0 SDK JAR from their CDN, so npm postinstall fails on @^2). v3 ships
# with cli-2025.2.1.jar and needs a JRE at runtime to invoke the SDK JAR.
# DO NOT purge nodejs or default-jre-headless — suitecloud shells out to both.
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates gnupg default-jre-headless && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    npm install -g @oracle/suitecloud-cli@^3 --acceptsuitecloudsdklicense && \
    apt-get purge -y --auto-remove curl gnupg && \
    rm -rf /var/lib/apt/lists/* /root/.npm

# Smoke check — fail the build if the suitecloud binary isn't on PATH (codex #14).
RUN suitecloud --version

# Copy backend application code (the build context is the repo root, so
# select backend/ explicitly).
COPY backend/ .

# Copy vendored Oracle SuiteCloud SDK skill content for RAG seeding.
# .dockerignore restricts this to oracle-vendored skills only — custom
# local skills (suitescript-engineer, etc.) stay out of the image.
COPY .claude/skills/ /app/.claude/skills/

# Create non-root user
RUN addgroup --system appuser && \
    adduser --system --ingroup appuser appuser && \
    mkdir -p /data && \
    chown -R appuser:appuser /app && \
    chown -R appuser:appuser /data
USER appuser

EXPOSE 8000

# Default: run FastAPI with production settings
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2"]
